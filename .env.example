# =====================================================
# GOBILIVE — ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in real values
# Production: https://gobilive-production.up.railway.app
# =====================================================

# Railway injects PORT automatically — do not set manually in production
# PORT=5000

NODE_ENV=development

# --- App URL ---
APP_URL=https://gobilive-production.up.railway.app

# --- MongoDB Atlas ---
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.kaci7dn.mongodb.net/gobilive?retryWrites=true&w=majority&appName=Cluster0

# --- JWT ---
JWT_SECRET=change_me_in_production

# --- CORS ---
# Comma-separated list of allowed origins. Leave blank to allow all (*).
# Example: https://gobilive-production.up.railway.app,https://admin.gobilive.com
ALLOWED_ORIGINS=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- Agora (Live Streaming) ---
AGORA_APP_ID=your_agora_app_id
AGORA_PRIMARY_CERTIFICATE=your_agora_certificate

# --- Firebase Admin ---
# Local dev: use file path
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Railway/Production: paste full service account JSON as single-line string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- Admin ---
ADMIN_API_KEY=gobilive_admin_dev_key

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# --- Google Play IAP ---
GOOGLE_PLAY_PACKAGE_NAME=com.gobilive.gobilive_app
