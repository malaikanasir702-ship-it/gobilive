# Dependencies
node_modules/

# Build output
dist/

# Environment secrets — NEVER commit these
.env
.env.local
.env.*.local

# Firebase service account keys
firebase-service-account.json
**/firebase-adminsdk*.json
*.json.key

# Local uploads (user-generated content, not source code)
uploads/

# Admin panel source (built output goes to public/admin — that IS committed)
# Note: /admin-panel/ scoped to root so src/features/admin-panel/ is NOT ignored
/admin-panel/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS artifacts
.DS_Store
Thumbs.db

# Editor config
.vscode/settings.json
.idea/

# TypeScript incremental build info
*.tsbuildinfo
