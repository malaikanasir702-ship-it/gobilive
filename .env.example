PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/gobilive?retryWrites=true&w=majority
JWT_SECRET=change_me_in_production

# CORS: comma-separated list of allowed origins for production.
# Leave blank (or omit) to allow all origins with wildcard (*).
# Example: https://app.gobilive.com,https://admin.gobilive.com
ALLOWED_ORIGINS=

STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

AGORA_APP_ID=your_agora_app_id
AGORA_PRIMARY_CERTIFICATE=your_agora_certificate

ADMIN_API_KEY=gobilive_admin_dev_key

# Firebase Admin — path to service account JSON OR inline JSON string
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
